# Provider API keys (optional)
OPENAI_API_KEY=dummy-openai-key
OPENAI_MODEL=gpt-5.4-mini

ANTHROPIC_API_KEY=dummy-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional Ollama host
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=lfm2.5-thinking:1.2b

# auto, or an specific model like gpt-5, claude-3-5-sonnet-latest, ollama, llama3.1
DEFAULT_MODEL=gpt-5.4-mini

# Folders the agent is allowed to index for knowledge (true/false per folder)
ENABLE_DIR_DOCUMENTS=true
ENABLE_DIR_DOWNLOADS=true
ENABLE_DIR_PICTURES=false
ENABLE_DIR_DESKTOP=false
